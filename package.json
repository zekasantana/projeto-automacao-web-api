{
  "name": "projeto-automacao-web-api",
  "version": "1.0.0",
  "main": "cypress.config.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test": "cypress run",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "report": "npm run test && npm run allure:generate"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "allure-commandline": "^2.43.0",
    "allure-cypress": "^3.10.2",
    "cypress": "^15.18.0",
    "esbuild": "^0.28.1"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": [
      "cypress/e2e/step_definitions/**/*.{js,mjs,ts,tsx}"
    ]
  },
  "keywords": [],
  "author": "Ezequias Santana de Melo",
  "license": "ISC",
  "description": "Projeto de automação Web e API com Cypress, Cucumber e JavaScript"
}
